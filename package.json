{
  "name": "skm-lit",
  "description": "skm-lit is a library for retrieving secrets stored in Cloud Storage",
  "version": "4.2.0",
  "author": "Joel Voss <mail@joelvoss.com>",
  "license": "MIT",
  "homepage": "https://github.com/joelvoss/skm-lit",
  "bugs": {
    "url": "https://github.com/joelvoss/skm-lit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelvoss/skm-lit.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "test": "./Taskfile.sh test",
    "prepublishOnly": "./Taskfile.sh build"
  },
  "dependencies": {
    "@google-cloud/storage": "7.19.0",
    "dotenv": "17.4.1",
    "mkdirp": "3.0.1",
    "readpkg-lit": "2.2.0",
    "tmp": "0.2.5"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/tmp": "^0.2.6",
    "jsdom": "29.0.2",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "typescript": "6.0.2",
    "vite": "8.0.6",
    "vite-plugin-bundle-dts": "0.3.0",
    "vitest": "4.1.3"
  }
}
